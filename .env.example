# Gemini
GEMINI_API_KEY=

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Confluence (defaults to JIRA_* values if not set separately)
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Google Cloud
GCS_BUCKET_NAME=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Firestore
FIRESTORE_COLLECTION=reports

# Agent
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# App
PORT=3001

# Playwright timeouts (ms)
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=15000

# HITL Settings
HITL_ENABLED=true
HITL_ACTION_THRESHOLD=0.7
HITL_VERIFY_THRESHOLD=0.6
HITL_MAX_WAIT_MS=120000
